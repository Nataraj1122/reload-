{
  "entities": {
    "NewsletterSubscription": {
      "title": "Newsletter Subscription",
      "description": "A user's subscription to the newsletter via email",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Subscriber's email address"
        },
        "subscribedAt": {
          "type": "timestamp",
          "description": "When the user subscribed"
        }
      },
      "required": ["email", "subscribedAt"]
    },
    "Category": {
      "title": "Product Category",
      "description": "Categories for grouping products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "image"]
    },
    "Product": {
      "title": "Shop Product",
      "description": "A product available for purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "images": { "type": "array" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "sizes": { "type": "array" },
        "isTrending": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "price", "categoryId", "images", "stock", "description", "sizes", "isTrending", "isNewArrival"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "zipCode": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "orderStatus": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "cancelledAt": { "type": "timestamp" }
      },
      "required": ["userId", "customerName", "customerEmail", "phoneNumber", "shippingAddress", "zipCode", "items", "totalAmount", "paymentMethod", "orderStatus", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile with basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "lastLogin": { "type": "timestamp" }
      },
      "required": ["uid", "name", "email", "createdAt", "lastLogin"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "name": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalSpent": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["totalOrders", "totalSpent"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin Users",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/newsletter/{subscriptionId}": {
      "schema": {
        "$ref": "#/entities/NewsletterSubscription"
      },
      "description": "Store newsletter subscription submissions."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Store orders."
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Store customers."
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Store admin roles."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": { "type": "object" },
      "description": "User cart items."
    },
    "/users/{userId}/wishlist/{itemId}": {
      "schema": { "type": "object" },
      "description": "User wishlist items."
    }
  }
}
